# ------------------------------------------------------------
# Generated outputs (keep notebook source only, not exported reports)
# ------------------------------------------------------------
*.html.bak
nbconvert-output/

# ------------------------------------------------------------
# World-model generated data — PERMANENT RULE: never commit generated CSVs.
# They are fully reproducible from the seed via `python -m world_model.run`.
# This guards against accidentally committing future V2/V3 outputs too.
# ------------------------------------------------------------
00_foundation/world_model/data/**/*.csv
00_foundation/world_model/data/**/_ground_truth.json
!00_foundation/world_model/data/**/.gitkeep

# L1 recovery generated artifacts — PERMANENT RULE: never commit cards or data.
# Cards/CSVs are reproducible from the (also-ignored) observation. Only synthetic
# in-code fixtures are committed (spec §11).
00_foundation/recovery/data/**/*.json
00_foundation/recovery/data/**/*.csv
!00_foundation/recovery/data/**/.gitkeep

# L3 grading generated reports — PERMANENT RULE: never commit reports/data.
# Reports are reproducible from the (manifest, card) pairs; only source + tests commit.
00_foundation/grading/data/**/*.json
00_foundation/grading/data/**/*.csv
!00_foundation/grading/data/**/.gitkeep

# Orchestration harness generated quads (manifest/card/CSVs) — PERMANENT RULE:
# never commit generated quads; reproducible from the fixed seed schedule.
00_foundation/harness/data/**/*.json
00_foundation/harness/data/**/*.csv
!00_foundation/harness/data/**/.gitkeep
# Temporary audit/inspection scripts (do not commit)
audit.py
inspect.py
impact.py
cleanup.py
check_readme.py
*_audit.py
*_inspect.py
*_result.txt
